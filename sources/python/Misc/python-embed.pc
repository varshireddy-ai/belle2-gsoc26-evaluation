# See: man pkg-config
prefix=/home/varshireddy/belle2-eval/install
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: Python
Description: Embed Python into an application
Requires:
Version: 3.12
Libs.private: -ldl 
Libs: -L${libdir} -lpython3.12
Cflags: -I${includedir}/python3.12
